rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'quxbashop@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. User Validation
    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 && data.email.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 128;
    }

    // 2. Product Validation
    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 256 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 128 &&
             data.price is number && data.price >= 0 &&
             data.originalPrice is number && data.originalPrice >= 0 &&
             data.discount is number && data.discount >= 0 && data.discount <= 100 &&
             data.imageUrl is string && data.imageUrl.size() <= 5000000 &&
             data.rating is number && data.rating >= 0 && data.rating <= 5 &&
             data.reviewsCount is number && data.reviewsCount >= 0 &&
             data.description is string && data.description.size() <= 10000 &&
             data.stock is number && data.stock >= 0 &&
             data.sellerId is string && data.sellerId.size() <= 128 &&
             data.sellerName is string && data.sellerName.size() <= 256;
    }

    // 3. Order Validation
    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.date is string && data.date.size() <= 64 &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.status is string && data.status.size() <= 64 &&
             data.deliveryAddress is string && data.deliveryAddress.size() <= 1024 &&
             data.paymentMethod is string && data.paymentMethod.size() <= 128 &&
             data.expectedDelivery is string && data.expectedDelivery.size() <= 128 &&
             data.customerEmail is string && data.customerEmail.size() > 0 && data.customerEmail.size() <= 128;
    }

    // 4. Advertisement Validation
    function isValidAdvert(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 256 &&
             data.subtitle is string && data.subtitle.size() > 0 && data.subtitle.size() <= 512 &&
             data.badge is string && data.badge.size() <= 128 &&
             data.buttonText is string && data.buttonText.size() <= 128 &&
             data.imageUrl is string && data.imageUrl.size() <= 5000000 &&
             data.category is string && data.category.size() <= 128 &&
             data.bgColor is string && data.bgColor.size() <= 128 &&
             (!('videoUrl' in data) || data.videoUrl == null || (data.videoUrl is string && data.videoUrl.size() <= 5000000)) &&
             data.createdAt is number;
    }

    // Global Safety Net default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get, list: if true;
      allow create, update: if isValidUser(incoming());
      allow delete: if isAdmin();
    }

    // --- Products Collection ---
    match /products/{productId} {
      // Anyone can read products count and list
      allow get, list: if true;

      // Anyone (admin, seller, guest, local) can create a validated product
      allow create: if isValidId(productId) && isValidProduct(incoming()) && (incoming().createdAt is number);

      // Anyone can update/delete products with proper structural validation
      allow update: if isValidId(productId) && isValidProduct(incoming());

      allow delete: if isValidId(productId);
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      // Anyone can read and list orders for tracking and dashboard management
      allow get, list: if true;

      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow update: if isValidId(orderId) && isValidOrder(incoming());
      allow delete: if isAdmin() || true;
    }

    // --- Adverts Collection ---
    match /adverts/{advertId} {
      allow get, list: if true;
      allow create, update: if isValidId(advertId) && isValidAdvert(incoming());
      allow delete: if isValidId(advertId);
    }
  }
}
