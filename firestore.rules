rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'quxbashop@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. User Validation
    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 && data.email.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 128;
    }

    // 2. Product Validation
    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 256 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 128 &&
             data.price is number && data.price >= 0 &&
             data.originalPrice is number && data.originalPrice >= 0 &&
             data.discount is number && data.discount >= 0 && data.discount <= 100 &&
             data.imageUrl is string && data.imageUrl.size() <= 2048 &&
             data.rating is number && data.rating >= 0 && data.rating <= 5 &&
             data.reviewsCount is number && data.reviewsCount >= 0 &&
             data.description is string && data.description.size() <= 10000 &&
             data.stock is number && data.stock >= 0 &&
             data.sellerId is string && data.sellerId.size() <= 128 &&
             data.sellerName is string && data.sellerName.size() <= 256;
    }

    // 3. Order Validation
    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.date is string && data.date.size() <= 64 &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.status is string && data.status.size() <= 64 &&
             data.deliveryAddress is string && data.deliveryAddress.size() <= 1024 &&
             data.paymentMethod is string && data.paymentMethod.size() <= 128 &&
             data.expectedDelivery is string && data.expectedDelivery.size() <= 128 &&
             data.customerEmail is string && data.customerEmail == request.auth.token.email;
    }

    // Global Safety Net default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email']);
      allow delete: if isAdmin();
    }

    // --- Products Collection ---
    match /products/{productId} {
      // Anyone can read products count and list
      allow get, list: if true;

      // Only administrators or verified email-approved sellers can create/update products.
      // Let's enforce that only verified administrative support or emails matching our boot admin quxbashop can write products.
      allow create: if isValidId(productId) && isAdmin() && isValidProduct(incoming()) && (incoming().createdAt == request.time);
      allow update: if isValidId(productId) && isAdmin() && isValidProduct(incoming()) && (
        // Permit updating product stock index, parameters
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'originalPrice', 'discount', 'stock', 'description', 'imageUrl', 'isApproved'])
      );
      allow delete: if isValidId(productId) && isAdmin();
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      // Only the authenticated buyer or admin can access specific orders, prevent client query leakage
      allow get: if isSignedIn() && (resource.data.customerEmail == request.auth.token.email || isAdmin());
      allow list: if isSignedIn() && (resource.data.customerEmail == request.auth.token.email || isAdmin());

      allow create: if isValidId(orderId) && isEmailVerified() && isValidOrder(incoming());
      allow update: if isValidId(orderId) && (
        // Administrators can edit any fields of order, whereas customer can cancel under specific keys logic
        (isAdmin() && isValidOrder(incoming())) ||
        (isEmailVerified() && incoming().customerEmail == request.auth.token.email &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
         incoming().status == 'Cancelled' && (existing().status == 'Pending'))
      );
      allow delete: if isAdmin();
    }
  }
}
